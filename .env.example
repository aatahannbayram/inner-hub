# Shared
NODE_ENV=development
PORT=3001
APP_URL=https://inner.digital

# Required
DATABASE_URL=postgresql://user:pass@host:5432/inner_hub
ADMIN_PASSCODE=
# Panel kayıt / Google ile yeni hesap — davet kodu
INVITE_PASSCODE=

# Higgsfield
HF_API_KEY=
HF_API_SECRET=

# Üyelik talebi bildirim maili (SMTP) — boş bırakılırsa mail gönderilmez
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

